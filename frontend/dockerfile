# ----------------------
# Build Stage
# ----------------------
FROM node:22-bullseye AS builder

WORKDIR /app

# Upgrade npm (to avoid old npm issues with Node 22)
RUN npm install -g npm@10

# Copy package.json and package-lock.json if present
COPY package*.json ./

# Install dependencies (use ci if lockfile exists, otherwise install)
RUN if [ -f package-lock.json ]; then npm install; else npm install; fi

# Copy the rest of your application
COPY . .

# Increase Node.js memory to prevent "heap out of memory"
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Build Next.js app
RUN npm run build

# ----------------------
# Production Stage
# ----------------------
FROM node:22-bullseye AS runner

WORKDIR /app
ENV NEXT_PUBLIC_NODE_ENV=production

# Copy only necessary files from builder
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public

# Expose port
EXPOSE 3000

# Start Next.js
CMD ["npm", "run", "start"]
