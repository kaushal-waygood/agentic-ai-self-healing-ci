{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "watch": "nodemon worker.js",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:debug": "NODE_OPTIONS=--experimental-vm-modules jest --detectOpenHandles --runInBand",
    "test:report": "jest --coverage && node tests/reports/jest-report.cjs",
    "test:open": "node tests/reports/open-jest-report.cjs",
    "prepare": "husky",
    "seed:jobs": "node scripts/seedExternalJobs.js",
    "k6": "k6 run --iterations 1 --vus 1 tests/k6/register_users.js",
    "k6:search": "k6 run --iterations 10 --vus 1 tests/k6/job_search.js",
    "k6:genai": "k6 run --vus 1 --duration 10s --summary-export=tests/output/genai-report.json tests/k6/generate_cv_cl.js && node tests/reports/genai-report.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "babel-jest": "^30.0.5",
    "jest": "^30.0.5",
    "jest-html-reporter": "^4.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@google/genai": "^1.10.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.10.0",
    "base64url": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "bullmq": "^5.63.1",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "core-js": "^3.47.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^13.4.0",
    "generic-pool": "^3.9.0",
    "google-auth-library": "^10.3.0",
    "google-spreadsheet": "^5.0.2",
    "googleapis": "^154.1.0",
    "helmet": "^8.1.0",
    "html-to-docx": "^1.8.0",
    "http-errors": "^2.0.0",
    "husky": "^9.1.7",
    "i18n-iso-countries": "^7.14.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "k6": "^0.0.0",
    "k6-html-reporter": "^0.0.4",
    "mammoth": "^1.11.0",
    "mongoose": "^8.16.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-pandoc": "^0.3.0",
    "nodemailer": "^7.0.5",
    "openai": "^6.16.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-poppler": "^0.2.1",
    "pdf2image": "^1.2.3",
    "pdf2pic": "^3.2.0",
    "puppeteer": "^24.20.0",
    "puppeteer-core": "^24.19.0",
    "razorpay": "^2.9.6",
    "recharts": "^3.1.2",
    "redis": "^5.8.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.1",
    "streamifier": "^0.1.1",
    "stripe": "^18.5.0",
    "tesseract.js": "^6.0.1",
    "uuid": "^11.1.0",
    "uuidv4": "^6.2.13",
    "xlsx": "^0.18.5"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!your-esm-module)/"
    ],
    "setupFilesAfterEnv": [
      "./tests/jest.setup.js"
    ],
    "reporters": [
      "default",
      [
        "jest-html-reporter",
        {
          "pageTitle": "Jest Test Report - ZobsAI Backend",
          "outputPath": "tests/output/jest-report.html",
          "includeFailureMsg": true,
          "includeConsoleLog": true,
          "theme": "darkTheme",
          "logo": "",
          "executionTimeWarningThreshold": 5,
          "dateFormat": "yyyy-mm-dd HH:MM:ss",
          "sort": "status",
          "includeObsoleteSnapshots": true
        }
      ]
    ],
    "coverageDirectory": "tests/output/coverage"
  }
}
