FROM node:20-slim

# Install required packages for Chromium/Puppeteer + PDF tools
# node:20-slim is Debian-based (glibc) so apt-get is available
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    chromium-sandbox \
    ca-certificates \
    fonts-freefont-ttf \
    dumb-init \
    pandoc \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Set Puppeteer to use system Chromium
ENV PUPPETEER_SKIP_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

WORKDIR /app

# Copy package files first for better caching
COPY package*.json ./

# Install production dependencies only
# node:20-slim is glibc — matches GitHub Actions runner, so
# @anush008/tokenizers-linux-x64-gnu (used by fastembed) resolves correctly
RUN npm install --omit=dev && \
    npm install pm2 -g && \
    npm cache clean --force

# Copy backend source code
COPY . .

EXPOSE 8080

# Run with PM2
CMD ["dumb-init", "pm2-runtime", "server.js"]
